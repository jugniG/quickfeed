# Database
DATABASE_URL=postgresql://user:password@localhost:5432/quickfeed

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:5173

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── DodoPayments ────────────────────────────────────────────────────────────
# Get these from https://app.dodopayments.com

# API key (test or live)
DODO_PAYMENTS_API_KEY=your-dodo-api-key

# Webhook signing key — from DodoPayments › Webhooks › your endpoint
DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-webhook-key

# Environment: "test_mode" (default) or "live_mode"
DODO_PAYMENTS_ENVIRONMENT=test_mode

# ─── Product IDs ─────────────────────────────────────────────────────────────
# No manual setup needed!
# Products are created automatically in DodoPayments on first checkout for each
# tier/interval combo and cached in the dodo_product_cache DB table.
# Pricing: $2 per 100MB/month. Yearly = 20% off. Tiers: 100,500,1024,2048,3072,4096,5120 MB

# ─── Cloudflare R2 (image storage) ───────────────────────────────────────────
# Create a bucket at https://dash.cloudflare.com → R2
# Then create an API token with Read+Write on that bucket
CF_R2_ACCOUNT_ID=your-cloudflare-account-id
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CF_R2_BUCKET_NAME=quickfeed-images
# Enable public access on the bucket, then set the public URL:
CF_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
