# Database
DATABASE_URL=postgresql://user:password@localhost:5432/quickfeed

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:5173

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── DodoPayments ────────────────────────────────────────────────────────────
# Get these from https://app.dodopayments.com

# API key (test or live)
DODO_PAYMENTS_API_KEY=your-dodo-api-key

# Webhook signing key — from DodoPayments › Webhooks › your endpoint
DODO_PAYMENTS_WEBHOOK_KEY=your-dodo-webhook-key

# Environment: "test_mode" (default) or "live_mode"
DODO_PAYMENTS_ENVIRONMENT=test_mode

# ─── Product IDs ─────────────────────────────────────────────────────────────
# Create products in DodoPayments dashboard, one per tier/interval combo.
# Naming convention: DODO_PRODUCT_{MB}_{INTERVAL}
# Supported tiers: 100, 500, 1024, 2048, 3072, 4096, 5120
# Pricing: $2 per 100MB/month. Yearly = 20% off.

DODO_PRODUCT_100_MONTHLY=pdt_xxxxxxx    # $4/mo  — 100 MB
DODO_PRODUCT_100_YEARLY=pdt_xxxxxxx     # $3.20/mo — 100 MB yearly
DODO_PRODUCT_500_MONTHLY=pdt_xxxxxxx    # $10/mo — 500 MB
DODO_PRODUCT_500_YEARLY=pdt_xxxxxxx     # $8/mo  — 500 MB yearly
DODO_PRODUCT_1024_MONTHLY=pdt_xxxxxxx   # $20/mo — 1 GB
DODO_PRODUCT_1024_YEARLY=pdt_xxxxxxx    # $16/mo — 1 GB yearly
DODO_PRODUCT_2048_MONTHLY=pdt_xxxxxxx   # $40/mo — 2 GB
DODO_PRODUCT_2048_YEARLY=pdt_xxxxxxx    # $32/mo — 2 GB yearly
DODO_PRODUCT_3072_MONTHLY=pdt_xxxxxxx   # $60/mo — 3 GB
DODO_PRODUCT_3072_YEARLY=pdt_xxxxxxx    # $48/mo — 3 GB yearly
DODO_PRODUCT_4096_MONTHLY=pdt_xxxxxxx   # $80/mo — 4 GB
DODO_PRODUCT_4096_YEARLY=pdt_xxxxxxx    # $64/mo — 4 GB yearly
DODO_PRODUCT_5120_MONTHLY=pdt_xxxxxxx   # $100/mo — 5 GB
DODO_PRODUCT_5120_YEARLY=pdt_xxxxxxx    # $80/mo — 5 GB yearly
